# העתק קובץ זה ל-.env.local לפיתוח מקומי
# ב-Vercel: הכנס את המשתנים דרך Settings > Environment Variables

# מפתח ה-API של OpenRouter
# קבל מפתח בכתובת: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# (אופציונלי) בחר מודל מתוך https://openrouter.ai/models
# ברירת מחדל: anthropic/claude-opus-4
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# (אופציונלי) הגבל CORS לדומיין שלך בלבד
# ALLOWED_ORIGIN=https://chavruta.vercel.app

# (אופציונלי) כתובת האתר (עבור HTTP-Referer ל-OpenRouter)
# APP_URL=https://chavruta.vercel.app
